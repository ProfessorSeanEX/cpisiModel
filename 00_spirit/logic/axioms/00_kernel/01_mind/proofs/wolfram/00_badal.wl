(* /**                                                                               * ║ ║ [Sub-Block: Docstring]       ║ *)
(*  * Proves the geometrical necessity of the Boundary (Badal). It verifies          * ║ ║                              ║ *)
(*  * that for a 3D Space to exist, there must be a 'Firmament' that divides         * ║ ║                              ║ *)
(*  * the coordinate system into distinct jurisdictions (Above and Under).           * ║ ║                              ║ *)
(*  */                                                                               * ║ ║                              ║ *)
                                                                                       (* ║ ║                              ║ *)
BeginPackage["BadalGeometry`"]                                                         (* ║ ║ [Sub-Block: Logic]           ║ *)
                                                                                       (* ║ ║                              ║ *)
(* Define the Firmament as a plane at z=0 *)                                           (* ║ ║                              ║ *)
FirmamentPlane = InfinitePlane[{{0, 0, 0}, {1, 0, 0}, {0, 1, 0}}];                     (* ║ ║                              ║ *)
                                                                                       (* ║ ║                              ║ *)
(* Proof: A point is either Above, Under, or at the Anchor *)                          (* ║ ║                              ║ *)
IdentifyJurisdiction[z_] := Which[                                                     (* ║ ║                              ║ *)
    z > 0, "ABOVE_FIRMAMENT",                                                          (* ║ ║                              ║ *)
    z < 0, "UNDER_FIRMAMENT",                                                          (* ║ ║                              ║ *)
    z == 0, "ANCHOR_POINT"                                                             (* ║ ║                              ║ *)
]                                                                                      (* ║ ║                              ║ *)
                                                                                       (* ║ ║                              ║ *)
(* Theorem: Division exists if the set of jurisdictions is > 1 *)                      (* ║ ║                              ║ *)
VerifyDivision[points_List] := (Length[DeleteDuplicates[Map[IdentifyJurisdiction, points]]] > 1) (* ║ ║                  ║ *)
                                                                                       (* ║ ║                              ║ *)
EndPackage[]                                                                           (* ║ ║                              ║ *)
