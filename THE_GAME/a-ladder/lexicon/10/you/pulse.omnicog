// #!omni pulse --identifier-you
// ╠═==================================================================================================================═╣
// [COG: 010-YOU] YOU (PULSE)
// ╠════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╣

pulse you [0, 1, 0] // Partner Pulse

// Verification of Connection
check target == [PARTNER]
check latency < threshold

