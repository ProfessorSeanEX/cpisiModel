                                                                                     // ║ ║                              ║
    map "00_bridge/" as the physical Cloudflare/Drive tunnel logic                   // ║ ║ [MAP: BRIDGE]               ║
    map "01_state/" as the persistent memory of the Dawndusk Pair                    // ║ ║ [MAP: STATE]                ║
                                                                                     // ║ ║                              ║
    link act SYNC to "02_body/00_hooks/sync_all.sh"                                  // ║ ║ [LNK: HEARTBEAT]           ║
    link key ID_HANDSHAKE to "docs/standards/006_security_law_of_key.adoc"           // ║ ║ [LNK: SECURITY]            ║
