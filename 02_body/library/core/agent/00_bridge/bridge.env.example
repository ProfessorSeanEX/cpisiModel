# [S-config-agent-bridge] Agent Bridge Environment Template
# ==============================================================================
# This template defines the required physical anchors for the Cloudflare and 
# Google Drive sync. The actual values are stored in ~/.config/cpisi/keys.env.
# ==============================================================================

# Node 1: Local Workstation Identity
CPISI_NODE_ID="DAWNDUSK_UBUNTU_01"
CPISI_LOCAL_ROOT="/media/seanje-lenox-wise/Project/cpisiModel"

# Node 2: The Cloud Bridge (Cloudflare)
# These credentials provide the secure tunnel for the Distributed Locus.
CLOUDFLARE_TUNNEL_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""

# Node 3: The Semantic Librarian (NotebookLM / Drive)
# The ID of the primary Capstone Notebook.
GOOGLE_DRIVE_SYNC_PATH="/home/seanje-lenox-wise/Google Drive/cpisi_mobile_state"
NOTEBOOKLM_NOTEBOOK_ID="d30c887d-a8d5-45cd-9fed-b169ec5d8d2b"

# The Triple Sync Pulse Interval (seconds)
CPISI_HEARTBEAT_TICK=300
